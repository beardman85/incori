---
import { getCollection } from 'astro:content';
import { site, contact, footerLinks, social, legalLinks } from '~/lib/site';
import Icon from './Icon.astro';
import HexMark from './HexMark.astro';
import SectionDivider from './SectionDivider.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const year = new Date().getFullYear();

// Full SVG element markup (stroke-based, 24x24) — injected via set:html.
const socialPaths: Record<string, string> = {
  facebook: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  instagram: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
};
---
<footer class="relative overflow-hidden bg-charcoal text-invert">
  <!-- Top gradient divider -->
  <SectionDivider />

  <!-- Ghosted, tilted brand emblem watermark bleeding off the right edge -->
  <div
    class="pointer-events-none absolute -right-24 -bottom-32 w-[30rem] rotate-[14deg] opacity-[0.07] sm:-right-16 md:w-[40rem] md:opacity-[0.08]"
    aria-hidden="true"
  >
    <HexMark id="footer-hex" />
  </div>

  <div class="container-page relative z-10 py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-12">
      <!-- Brand + contact -->
      <div class="md:col-span-4">
        <img src="/logos/logo-horizontal-white.png" alt={site.name} width="640" height="172" class="h-12 w-auto md:h-14" />
        <p class="mt-5 max-w-xs text-[0.98rem] leading-relaxed text-white/70">
          {site.shortDescription}
        </p>
        <p class="mt-3 text-sm font-medium text-white/50">Serving Omaha, NE since {site.foundedYear}.</p>
        <ul class="mt-6 space-y-3 text-[0.98rem]">
          <li>
            <a href={contact.phoneHref} class="group inline-flex items-center gap-3 text-white/85 hover:text-white focus-visible:outline-cyan">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-white/10 text-cyan"><Icon name="phone" size={18} /></span>
              {contact.phone}
            </a>
          </li>
          <li>
            <a href={contact.emailHref} class="group inline-flex items-center gap-3 text-white/85 hover:text-white focus-visible:outline-cyan">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-white/10 text-cyan"><Icon name="mail" size={18} /></span>
              {contact.email}
            </a>
          </li>
          <li>
            <a href={contact.mapHref} target="_blank" rel="noopener" class="group inline-flex items-start gap-3 text-white/85 hover:text-white focus-visible:outline-cyan">
              <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-full bg-white/10 text-cyan"><Icon name="map-pin" size={18} /></span>
              <span>{contact.address.street}<br />{contact.address.city}, {contact.address.state} {contact.address.zip}</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div class="md:col-span-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-cyan">Our Services</h2>
        <ul class="mt-5 grid grid-cols-1 gap-x-8 gap-y-2.5 sm:grid-cols-2">
          {services.map((s) => (
            <li>
              <a href={`/services/#${s.id}`} class="text-white/70 transition-colors hover:text-white focus-visible:outline-cyan">
                {s.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-3">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-cyan">Quick Links</h2>
        <ul class="mt-5 space-y-2.5">
          {footerLinks.map((l) => (
            <li>
              <a href={l.href} class="text-white/70 transition-colors hover:text-white focus-visible:outline-cyan">{l.label}</a>
            </li>
          ))}
        </ul>
        <div class="mt-7 flex gap-3">
          {social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={s.label}
              class="grid h-10 w-10 place-items-center rounded-full bg-white/10 text-white transition-colors hover:bg-brand-gradient focus-visible:outline-cyan"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={socialPaths[s.icon]} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 grid gap-4 border-t border-white/10 pt-7 text-sm text-white/55 sm:grid-cols-3 sm:items-center">
      <p class="text-center sm:text-left">&copy; {year} {site.legalName}</p>
      <p class="text-center">
        Powered by
        <a href={site.creditUrl} target="_blank" rel="noopener" class="font-semibold text-white/85 transition-colors hover:text-white focus-visible:outline-cyan">{site.credit}</a>
      </p>
      <nav class="flex justify-center gap-6 sm:justify-end" aria-label="Legal">
        {legalLinks.map((l) => (
          <a href={l.href} class="transition-colors hover:text-white/90 focus-visible:outline-cyan">{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
