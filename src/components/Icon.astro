---
/**
 * Inline SVG icon set (stroke-based, lucide-style).
 * Decorative by default (aria-hidden). Pass `title` to make it labelled.
 */
interface Props {
  name: string;
  class?: string;
  size?: number;
  title?: string;
}
const { name, class: className = '', size = 24, title } = Astro.props;

const paths: Record<string, string> = {
