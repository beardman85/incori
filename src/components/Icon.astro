  'day-support': '<rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/><path d="m8.5 14 2.2 2.2 4.3-4.3"/>',
  residential: '<path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/><path d="M10 20v-5h4v5"/>',
  family: '<path d="M12 21s-7-4.4-9.3-8.6C1 9.3 2.6 6 6 6c1.9 0 3.2 1 4 2.2C10.8 7 12.1 6 14 6c3.4 0 5 3.3 3.3 6.4C19 16.6 12 21 12 21Z"/>',
  respite: '<path d="M4 11h13a3 3 0 0 1 0 6H8a4 4 0 0 1-4-4Z"/><path d="M8 8c0-1 .8-1.5.8-2.5S8 3.5 8 3M12 8c0-1 .8-1.5.8-2.5S12 3.5 12 3"/><path d="M17 17v1a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-1"/>',
  vocational: '<rect x="3" y="7.5" width="18" height="12" rx="2"/><path d="M9 7.5V6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v1.5M3 13h18"/>',
  'supported-living': '<path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/><path d="M12 17.5s-3-1.8-3-3.6c0-1 .8-1.9 1.8-1.9.7 0 1 .4 1.2.7.2-.3.5-.7 1.2-.7 1 0 1.8.9 1.8 1.9 0 1.8-3 3.6-3 3.6Z"/>',
  transitional: '<path d="M3 12h13M12 5l7 7-7 7"/><path d="M4 5v3M4 16v3"/>',
  transportation: '<path d="M3 13.5 4.6 7A2 2 0 0 1 6.5 5.5h8.7a2 2 0 0 1 1.8 1.1L20 13.5"/><path d="M3 13.5h18V18a1 1 0 0 1-1 1h-2v-2H6v2H4a1 1 0 0 1-1-1Z"/><circle cx="7" cy="16" r="1.2"/><circle cx="17" cy="16" r="1.2"/>',
  // value / generic icons
  heart: '<path d="M12 21s-7-4.4-9.3-8.6C1 9.3 2.6 6 6 6c1.9 0 3.2 1 4 2.2C10.8 7 12.1 6 14 6c3.4 0 5 3.3 3.3 6.4C19 16.6 12 21 12 21Z"/>',
  shield: '<path d="M12 3 5 6v5c0 4.4 3 7.6 7 9 4-1.4 7-4.6 7-9V6Z"/><path d="m9 12 2 2 4-4"/>',
  users: '<circle cx="9" cy="8" r="3"/><path d="M3 20v-1a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v1"/><path d="M16 4.5a3 3 0 0 1 0 6M17 14.2a5 5 0 0 1 4 4.8V20"/>',
  star: '<path d="m12 3 2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.2l1-5.8L3.5 9.2l5.9-.9Z"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5Z"/>',
  // ui icons
  phone: '<path d="M4 5.5C4 4.7 4.7 4 5.5 4H8l1.5 4-2 1.4a12 12 0 0 0 5.1 5.1L14 12.5 18 14v2.5c0 .8-.7 1.5-1.5 1.5A13.5 13.5 0 0 1 4 5.5Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  'map-pin': '<path d="M12 21s-6-5-6-10a6 6 0 0 1 12 0c0 5-6 10-6 10Z"/><circle cx="12" cy="11" r="2.2"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  check: '<path d="m5 12 4.5 4.5L19 7"/>',
  menu: '<path d="M4 6h16M4 12h16M4 18h16"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  quote: '<path d="M7 7h4v6a4 4 0 0 1-4 4M15 7h4v6a4 4 0 0 1-4 4"/>',
};

const d = paths[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : '') + d}
/>
