---
import HexMark from './HexMark.astro';
/**
 * Reusable dark interior-page hero: eyebrow + title + intro, with the ghost
 * emblem and ambient glow. `title` accepts inline HTML (e.g. a text-gradient span).
 * Use the default slot for extra content (quick-nav chips, CTAs).
 */
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---
<section class="relative overflow-hidden bg-ink text-white">
  <div class="pointer-events-none absolute -left-24 top-1/3 h-96 w-96 rounded-full bg-cyan/15 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-[6%] top-24 hidden w-36 opacity-30 lg:block xl:w-44" aria-hidden="true">
    <HexMark animate id="pagehero-hex" />
  </div>

  <div class="container-page relative py-28 md:py-36">
    <div class="max-w-3xl">
      {eyebrow && (
        <span class="mb-5 inline-flex w-fit items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.16em] text-cyan ring-1 ring-white/15 backdrop-blur">
          {eyebrow}
        </span>
      )}
      <h1 class="text-hero font-semibold leading-[0.98] tracking-tight">
        <Fragment set:html={title} />
      </h1>
      {intro && <p class="mt-6 max-w-2xl text-lead text-white/80">{intro}</p>}
      <slot />
    </div>
  </div>
</section>
