---
import Icon from '~/components/Icon.astro';
import Button from '~/components/Button.astro';
interface Props {
  slug: string;
  title: string;
  summary: string;
  icon: string;
  image?: string;
  imageAlt?: string;
}
const { slug, title, summary, icon, image, imageAlt } = Astro.props;
const learnMore = `/services/${slug}/`;
const request = `/request-services/?service=${slug}`;
---
<article class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-charcoal/8 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:shadow-xl hover:ring-charcoal/12">
  {image && (
    <a href={learnMore} class="relative block aspect-[16/10] overflow-hidden focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-azure" aria-label={`${title} — learn more`}>
      <img
        src={image}
        alt={imageAlt ?? ''}
        width="640"
        height="400"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/45 to-transparent"></div>
      <span class="absolute bottom-3 left-3 grid h-11 w-11 place-items-center rounded-xl bg-white/95 text-charcoal shadow-md ring-1 ring-charcoal/5 backdrop-blur">
        <Icon name={icon} size={22} />
      </span>
    </a>
  )}
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-h3 font-semibold text-charcoal">
      <a href={learnMore} class="rounded transition-colors hover:text-cyan-deep focus-visible:outline-azure">{title}</a>
    </h3>
    <p class="mt-2 flex-1 text-[0.97rem] leading-relaxed text-steel">{summary}</p>
    <div class="mt-5 flex flex-wrap gap-2.5">
      <Button href={learnMore} variant="secondary" size="sm">Learn more</Button>
      <Button href={request} variant="ghost" size="sm" icon="">Request</Button>
    </div>
  </div>
</article>
