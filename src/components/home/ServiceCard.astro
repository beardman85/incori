---
import Icon from '~/components/Icon.astro';
interface Props {
  href: string;
  title: string;
  summary: string;
  icon: string;
  image?: string;
  imageAlt?: string;
}
const { href, title, summary, icon, image, imageAlt } = Astro.props;
---
<a
  href={href}
  class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-charcoal/8 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:shadow-xl hover:ring-charcoal/12 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-azure"
>
  {image && (
    <div class="relative aspect-[16/10] overflow-hidden">
      <img
        src={image}
        alt={imageAlt ?? ''}
        width="640"
        height="400"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/45 to-transparent"></div>
      <!-- Icon badge -->
      <span class="absolute bottom-3 left-3 grid h-11 w-11 place-items-center rounded-xl bg-white/95 text-charcoal shadow-md ring-1 ring-charcoal/5 backdrop-blur">
        <Icon name={icon} size={22} />
      </span>
    </div>
  )}
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-h3 font-semibold text-charcoal">{title}</h3>
    <p class="mt-2 text-[0.97rem] leading-relaxed text-steel">{summary}</p>
    <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-cyan-deep">
      Learn more
      <Icon name="arrow" size={16} class="transition-transform duration-300 group-hover:translate-x-1" />
    </span>
  </div>
</a>
