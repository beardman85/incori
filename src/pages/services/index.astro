---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import SectionDivider from '~/components/SectionDivider.astro';
import CtaBanner from '~/components/CtaBanner.astro';
import Reveal from '~/components/Reveal.astro';
import ServiceCard from '~/components/home/ServiceCard.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Services"
  description="Explore Inclusion Oriented's full range of developmental-disability support services in Omaha, NE — from adult day services and community integration to residential, vocational, family support, respite, and transportation."
>
  <PageHero
    eyebrow="What We Offer"
    title={`Support for every part of <span class="text-gradient">daily life.</span>`}
    intro="At Inclusion Oriented, we offer a comprehensive range of services designed to meet the unique needs of individuals with physical and mental impairments — each one person-centered, and built to foster independence, dignity, and community."
  />

  <SectionDivider />

  <!-- Services grid -->
  <section class="bg-fog py-20 md:py-24" aria-label="All services">
    <div class="container-page">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => (
          <Reveal delay={(i % 3) * 80}>
            <ServiceCard
              slug={s.id}
              title={s.data.title}
              summary={s.data.summary}
              icon={s.data.icon}
              image={s.data.image}
              imageAlt={s.data.imageAlt}
            />
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider />

  <CtaBanner
    id="services-cta"
    title={`Not sure which service <span class="text-gradient">fits best?</span>`}
    intro="Every plan starts with a conversation. Tell us about your needs and our team will help you find the right support."
  />
</BaseLayout>
