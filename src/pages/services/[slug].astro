---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionDivider from '~/components/SectionDivider.astro';
import CtaBanner from '~/components/CtaBanner.astro';
import Reveal from '~/components/Reveal.astro';
import Button from '~/components/Button.astro';
import Icon from '~/components/Icon.astro';
import HexMark from '~/components/HexMark.astro';
import { cta, contact } from '~/lib/site';

export const getStaticPaths = (async () => {
  const services = await getCollection('services');
  return services.map((s) => ({ params: { slug: s.id }, props: { service: s } }));
}) satisfies GetStaticPaths;

const { service } = Astro.props;
const { Content } = await render(service);
const d = service.data;

const all = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const others = all.filter((s) => s.id !== service.id);
const requestHref = `/request-services/?service=${service.id}`;
---
<BaseLayout title={`${d.title} — Services`} description={d.summary}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink text-white" aria-labelledby="svc-title">
    <div class="pointer-events-none absolute -left-24 top-1/3 h-96 w-96 rounded-full bg-cyan/15 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute right-[4%] top-16 hidden w-28 opacity-25 xl:block" aria-hidden="true">
      <HexMark animate id="svc-hex" />
    </div>

    <div class="container-page relative py-16 md:py-24">
      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-sm text-white/55" aria-label="Breadcrumb">
        <a href="/services/" class="hover:text-white focus-visible:outline-cyan">Services</a>
        <Icon name="arrow" size={14} class="text-white/30" />
        <span class="text-white/80">{d.title}</span>
      </nav>

      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          {d.subtitle && (
            <span class="mb-4 inline-flex w-fit items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-[0.14em] text-cyan ring-1 ring-white/15">
              {d.subtitle}
            </span>
          )}
          <h1 id="svc-title" class="text-h1 font-semibold leading-[1.02] tracking-tight">{d.title}</h1>
          <p class="mt-5 max-w-xl text-lead text-white/80">{d.summary}</p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <Button href={requestHref} size="lg" variant="primary">Request this service</Button>
            <a href={contact.phoneHref} class="inline-flex min-h-12 items-center gap-2 rounded-full px-6 py-4 font-semibold text-white ring-1 ring-white/25 transition-colors hover:bg-white/10 focus-visible:outline-cyan">
              <Icon name="phone" size={18} class="text-cyan" /> {contact.phone}
            </a>
          </div>
        </div>

        {d.image && (
          <div class="relative">
            <div class="overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10">
              <img
                src={d.image}
                alt={d.imageAlt ?? ''}
                width="1200"
                height="800"
                fetchpriority="high"
                decoding="async"
                class="aspect-[3/2] w-full object-cover"
              />
            </div>
            <span class="absolute -bottom-5 left-6 grid h-14 w-14 place-items-center rounded-2xl bg-brand-gradient text-white shadow-lg ring-4 ring-ink">
              <Icon name={d.icon} size={26} />
            </span>
          </div>
        )}
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Full write-up -->
  <section class="bg-white py-16 md:py-24" aria-labelledby="overview">
    <div class="container-page grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-8">
        <h2 id="overview" class="text-h3 font-semibold text-charcoal">Overview</h2>
        <div class="rich-text mt-5 text-lead leading-relaxed">
          <Content />
        </div>
        <div class="mt-9 flex flex-wrap gap-3">
          <Button href={requestHref} variant="secondary">Request this service</Button>
          <Button href="/services/" variant="ghost" icon="arrow">All services</Button>
        </div>
      </div>

      <!-- Sidebar: quick help -->
      <aside class="lg:col-span-4">
        <div class="rounded-2xl bg-fog p-6 ring-1 ring-charcoal/8">
          <h2 class="text-h3 font-semibold text-charcoal">Have questions?</h2>
          <p class="mt-2 text-[0.98rem] leading-relaxed text-steel">
            Our team is here to help you understand your options and find the right fit.
          </p>
          <ul class="mt-5 space-y-3 text-[0.98rem]">
            <li>
              <a href={contact.phoneHref} class="group inline-flex items-center gap-3 text-charcoal hover:text-cyan-deep focus-visible:outline-azure">
                <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-gradient text-white"><Icon name="phone" size={17} /></span>
                {contact.phone}
              </a>
            </li>
            <li>
              <a href={contact.emailHref} class="group inline-flex items-center gap-3 text-charcoal hover:text-cyan-deep focus-visible:outline-azure">
                <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-gradient text-white"><Icon name="mail" size={17} /></span>
                {contact.email}
              </a>
            </li>
          </ul>
          <div class="mt-6">
            <Button href={requestHref} size="sm" variant="primary" class="w-full">Request this service</Button>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Explore other services -->
  <section class="bg-fog py-16 md:py-24" aria-labelledby="others">
    <div class="container-page">
      <h2 id="others" class="text-h2 font-semibold text-charcoal">Explore other services</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {others.map((s) => (
          <a
            href={`/services/${s.id}/`}
            class="group flex items-start gap-4 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-charcoal/8 transition-all hover:-translate-y-0.5 hover:shadow-md focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-azure"
          >
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-gradient text-white shadow">
              <Icon name={s.data.icon} size={22} />
            </span>
            <span>
              <span class="block font-display font-semibold text-charcoal">{s.data.title}</span>
              <span class="mt-0.5 inline-flex items-center gap-1 text-sm font-semibold text-cyan-deep">
                Learn more <Icon name="arrow" size={14} class="transition-transform group-hover:translate-x-0.5" />
              </span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider />

  <CtaBanner
    id={`svc-cta`}
    title={`Ready to get <span class="text-gradient">started?</span>`}
    intro="Reach out today and our team will guide you through the next steps."
  />
</BaseLayout>
