---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import HexMark from '~/components/HexMark.astro';
import { primaryNav } from '~/lib/site';
---
<BaseLayout title="Page Not Found" noindex>
  <section class="relative overflow-hidden bg-ink text-white">
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan/10 blur-3xl" aria-hidden="true"></div>
    <div class="container-page relative flex min-h-[80svh] flex-col items-center justify-center py-32 text-center">
      <div class="w-24 opacity-90" aria-hidden="true"><HexMark id="nf-hex" /></div>
      <p class="mt-8 font-display text-6xl font-semibold text-gradient">404</p>
      <h1 class="mt-4 text-h2 font-semibold">This page took a different path.</h1>
      <p class="mt-4 max-w-md text-lead text-white/75">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>
      <div class="mt-8">
        <Button href="/" size="lg" variant="primary" icon="arrow">Back to home</Button>
      </div>
      <nav class="mt-10 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/60" aria-label="Helpful links">
        {primaryNav.map((l) => (
          <a href={l.href} class="hover:text-white focus-visible:outline-cyan">{l.label}</a>
        ))}
      </nav>
    </div>
  </section>
</BaseLayout>
