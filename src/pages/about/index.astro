---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import SectionDivider from '~/components/SectionDivider.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import CtaBanner from '~/components/CtaBanner.astro';
import Reveal from '~/components/Reveal.astro';
import Button from '~/components/Button.astro';
import Icon from '~/components/Icon.astro';
import { site } from '~/lib/site';

const values = (await getCollection('values')).sort((a, b) => a.data.order - b.data.order);
const yearsServing = new Date().getFullYear() - site.foundedYear;

const missionVision = [
  {
    key: 'mission',
    icon: 'star',
    title: 'Our Mission',
    text: 'We aim to empower individuals with the skills and resources needed to live independently and achieve their goals.',
  },
  {
    key: 'vision',
    icon: 'compass',
    title: 'Our Vision',
    text: 'We envision a world where individuals with disabilities are fully integrated into all aspects of community life — living independently and achieving their personal goals.',
  },
];
---
<BaseLayout
  title="About Us"
  description="Founded in 2019 by Aminou B Amadou, Inclusion Oriented delivers person-centered developmental-disability services in Omaha, NE — built on inclusion, empowerment, and community."
>
  <PageHero
    eyebrow="About Us"
    title={`Empowering lives, building <span class="text-gradient">community.</span>`}
    intro="Inclusion Oriented provides innovative, high-quality services that enable individuals with disabilities to lead meaningful, productive lives as vital members of their community."
  />

  <SectionDivider />

  <!-- Our Story -->
  <section class="bg-white py-20 md:py-28" aria-labelledby="story-title">
    <div class="container-page grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <Reveal class="relative order-last lg:order-first">
        <div class="overflow-hidden rounded-2xl shadow-2xl ring-1 ring-charcoal/5">
          <img
            src="/images/working-together.webp"
            alt="The Inclusion Oriented team supporting one another"
            width="1200"
            height="800"
            loading="lazy"
            decoding="async"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
        <div class="absolute -bottom-6 -right-4 rounded-2xl bg-charcoal p-5 text-white shadow-xl sm:-right-6 sm:p-6">
          <div class="font-display text-4xl font-semibold text-gradient">{yearsServing}+</div>
          <div class="mt-1 text-sm text-white/70">years serving<br />Omaha families</div>
        </div>
        <div class="absolute -left-4 -top-4 -z-10 h-32 w-32 rounded-2xl bg-brand-gradient opacity-20 blur-2xl" aria-hidden="true"></div>
      </Reveal>

      <Reveal>
        <span class="mb-3 inline-block text-sm font-semibold uppercase tracking-[0.14em] text-gradient-ink">Our Story</span>
        <h2 id="story-title" class="text-h2 font-semibold text-charcoal">Serving Omaha since {site.foundedYear}.</h2>
        <div class="rich-text mt-5 text-lead leading-relaxed">
          <p>
            Inclusion Oriented was founded by <strong>Aminou B Amadou</strong>, a former Direct
            Support Professional and Director of Services. In 2019, Amin co-founded Prism of
            Possibilities, bringing his passion for person-centered initiatives to life.
          </p>
          <p>
            Since then, Inclusion Oriented has grown to serve numerous individuals — providing
            essential services that improve quality of life and foster a genuine sense of
            belonging within the community.
          </p>
        </div>
        <div class="mt-8">
          <Button href="/services/" variant="secondary">Explore our services</Button>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="relative overflow-hidden bg-charcoal py-20 text-white md:py-28" aria-labelledby="mv-title">
    <div class="pointer-events-none absolute right-0 top-0 h-80 w-80 rounded-full bg-azure/10 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute bottom-0 left-1/4 h-80 w-80 rounded-full bg-ember/10 blur-3xl" aria-hidden="true"></div>
    <div class="container-page relative">
      <SectionHeading
        titleId="mv-title"
        eyebrow="What Drives Us"
        title="Mission &amp; vision"
        intro="A clear purpose and an ambitious picture of the future — the compass for everything we do."
        invert
      />
      <div class="mt-14 grid gap-6 md:grid-cols-2">
        {missionVision.map((m) => (
          <Reveal>
            <div class="h-full rounded-2xl bg-white/5 p-8 ring-1 ring-white/10">
              <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-gradient text-white shadow-lg">
                <Icon name={m.icon} size={28} />
              </span>
              <h3 class="mt-6 text-h3 font-semibold text-white">{m.title}</h3>
              <p class="mt-3 text-lead leading-relaxed text-white/70">{m.text}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-fog py-20 md:py-28" aria-labelledby="values-title">
    <div class="container-page">
      <SectionHeading
        titleId="values-title"
        eyebrow="Our Values"
        title="The principles behind our care"
        intro="Five commitments that shape how we show up for every individual and family we serve."
      />
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {values.map((v) => (
          <Reveal>
            <div class="h-full rounded-2xl bg-white p-6 shadow-sm ring-1 ring-charcoal/8">
              <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-gradient text-white shadow">
                <Icon name={v.data.icon} size={24} />
              </span>
              <h3 class="mt-5 text-h3 font-semibold text-charcoal">{v.data.title}</h3>
              <p class="mt-2 text-[0.98rem] leading-relaxed text-steel">{v.data.summary}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="bg-white py-20 md:py-28" aria-labelledby="leader-title">
    <div class="container-page grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <Reveal class="lg:col-span-5">
        <div class="relative mx-auto max-w-sm">
          <div class="absolute inset-0 -rotate-3 rounded-3xl bg-brand-gradient opacity-90" aria-hidden="true"></div>
          <img
            src="/images/headshot.png"
            alt="Aminou B Amadou, Executive Director & Founder"
            width="600"
            height="720"
            loading="lazy"
            decoding="async"
            class="relative aspect-[5/6] w-full rounded-3xl object-cover object-top shadow-2xl ring-1 ring-charcoal/5"
          />
        </div>
      </Reveal>

      <Reveal class="lg:col-span-7">
        <span class="mb-3 inline-block text-sm font-semibold uppercase tracking-[0.14em] text-gradient-ink">Meet Our Founder</span>
        <h2 id="leader-title" class="text-h2 font-semibold text-charcoal">Aminou B Amadou</h2>
        <p class="mt-1 text-lead font-medium text-cyan-deep">Executive Director &amp; Founder</p>
        <div class="rich-text mt-5 text-lead leading-relaxed">
          <p>
            Aminou brings a wealth of experience as a Direct Support Professional and former
            co-founder of Prism of Possibilities — a company specializing in services for
            physically and mentally impaired individuals. He has dedicated himself to enriching
            our communities by creating avenues for clients to acquire new skills and strengthen
            existing ones.
          </p>
          <p>
            Amin's success and deep compassion in this field stem from personal experience with
            his younger son. His family embarked on an incredibly successful journey to ensure he
            received all the care necessary to thrive in every aspect of life. Through Inclusion
            Oriented, Amin aims not just to provide great services, but to cultivate a vibrant,
            inclusive environment for all.
          </p>
        </div>

        <figure class="mt-8 rounded-2xl border-l-4 border-cyan bg-fog p-6">
          <Icon name="quote" size={28} class="text-cyan-deep" />
          <blockquote class="mt-2 text-h3 font-display font-medium text-charcoal">
            Let us go forward in this battle fortified by the conviction that those who labour in
            the service of a great and good cause will never fail.
          </blockquote>
          <figcaption class="mt-3 text-sm font-semibold uppercase tracking-wider text-steel">— Winston Churchill</figcaption>
        </figure>
      </Reveal>
    </div>
  </section>

  <SectionDivider />

  <CtaBanner
    id="about-cta"
    title={`Let's build a plan <span class="text-gradient">together.</span>`}
    intro="Whether you're seeking services or looking to join our mission, we'd love to hear from you."
  />
</BaseLayout>
